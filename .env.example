# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Chave secreta para assinar os cookies de sessão (use algo longo e aleatório)
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria-aqui

# Hash bcrypt da senha do administrador
# Gere com: python -c "import bcrypt; print(bcrypt.hashpw('SUA_SENHA'.encode(), bcrypt.gensalt()).decode())"
HASH_LUCAS=$2b$12$EXEMPLO_SUBSTITUA_PELO_HASH_GERADO_DA_SUA_SENHA

# Opcional: chave Fernet para criptografar observações
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# Configurações (valores padrão já funcionam para desenvolvimento)
DB_FILE=/data/dados_inspecoes.db
IMG_DIR=/data/fotos
MAX_SIZE_MB=5
MAX_LOGIN_ATTEMPTS=5
SESSION_TIMEOUT_MINUTES=60
