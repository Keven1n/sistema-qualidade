# ─────────────────────────────────────────────────────────────
# ARQUIVO DE EXEMPLO - VARIÁVEIS DE AMBIENTE (.env)

# --- Configurações de Banco de Dados ---
# Usado para sobrescrever o SQLite pelo PostgreSQL via Docker Compose
# Exemplo local (Docker): postgresql://admin:adminpassword@db:5432/qualidade
DATABASE_URL=sqlite:////data/dados_inspecoes.db

# --- Segurança e Sessões ---
# CHAVE SECRETA: Use uma string longa e aleatória em produção. 
# Exemplo para gerar uma chave forte no terminal: openssl rand -hex 32
SECRET_KEY=troque-em-producao-use-valor-longo-aleatorio

# Tempo de expiração da sessão (em minutos)
SESSION_TIMEOUT_MINUTES=60

# --- Senha do Usuário Admin Inicial ---
# O sistema criará o usuário 'admin' (admin) com este hash bcrypt no primeiro boot.
# Exemplo de hash bcrypt para a senha '123456':
# HASH_ADMIN="$2b$12$EixZaYVK1fsbw1ZfbX3OXePaWxn96p36WQoeG6Lruj3vjPGga31lW"
HASH_ADMIN=

# --- Configurações de Upload ---
# Tamanho máximo de upload em Megabytes
MAX_SIZE_MB=5

# Diretório onde as imagens serão salvas
IMG_DIR=/data/fotos
